# ============================================================================
# Lead Booster Pro — environment template.
# Copy to .env.local (web) / .env (worker) and fill in. Never commit real keys.
# ============================================================================

# --- Supabase (database + auth) --------------------------------------------
# From your Supabase project settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose to the browser. Used by API routes and the worker.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Redis (BullMQ job queue between web API and Hetzner worker) ------------
REDIS_URL=redis://localhost:6379

# --- AI (customer supplies their own; this is the platform default) ---------
ANTHROPIC_API_KEY=sk-ant-...
# Model ids used by the pipeline.
ANTHROPIC_MODEL_EXTRACT=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SCORE=claude-sonnet-5

# --- Discovery / search (free tier available for most) ----------------------
GOOGLE_PLACES_API_KEY=
SERPER_API_KEY=

# --- Paid enrichment / verification (optional; gated behind paid switch) ----
HUNTER_API_KEY=
APOLLO_API_KEY=
PDL_API_KEY=
NEVERBOUNCE_API_KEY=
BRIGHTDATA_API_KEY=
APIFY_TOKEN=

# --- Government registries (free keys) --------------------------------------
SAM_GOV_API_KEY=
FMCSA_WEBKEY=

# --- Worker tuning ----------------------------------------------------------
WORKER_CONCURRENCY=4
# Playwright: use the pre-installed Chromium in prod images.
PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers

# --- App URLs ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Shared secret the worker uses to call back into the web API (realtime is via
# Supabase, but this authenticates any direct callbacks).
WORKER_CALLBACK_SECRET=change-me
