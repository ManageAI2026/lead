# ============================================================================
# Lead Booster Pro dashboard — environment template.
# Copy to apps/web/.env.local and fill in. Never commit real keys.
#
# COMPANION MODE: this app is a companion to the ManageAI server. It points at
# the SHARED Supabase project (the server owns the schema + migrations) and,
# in Phase 2, dispatches actions through the server gateway.
# ============================================================================

# --- Supabase (SHARED server project: database + auth) ----------------------
# Use the shared server project's values (Supabase settings → API), NOT a
# standalone project. The server repo owns the schema; do not run migrations
# from this repo.
NEXT_PUBLIC_SUPABASE_URL=https://SHARED-SERVER-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=shared-project-anon-key
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=shared-project-service-role-key
# REQUIRED — the shared project's JWT secret (Supabase settings → API → JWT).
# Server-side verification of Supabase-issued JWTs fails without it.
SUPABASE_JWT_SECRET=shared-project-jwt-secret

# --- Server gateway (Phase 2 — uncomment once the gateway is booted) ---------
# NEXT_PUBLIC_GATEWAY_URL=https://gateway.manageai.example
# GATEWAY_API_SECRET=change-me

# --- AI (customer supplies their own; this is the platform default) ---------
ANTHROPIC_API_KEY=sk-ant-...
# Model ids used by the pipeline.
ANTHROPIC_MODEL_EXTRACT=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SCORE=claude-sonnet-5

# --- Discovery / search (free tier available for most) ----------------------
GOOGLE_PLACES_API_KEY=
SERPER_API_KEY=

# --- Paid enrichment / verification (optional; gated behind paid switch) ----
HUNTER_API_KEY=
APOLLO_API_KEY=
PDL_API_KEY=
NEVERBOUNCE_API_KEY=
BRIGHTDATA_API_KEY=
APIFY_TOKEN=

# --- Government registries (free keys) --------------------------------------
SAM_GOV_API_KEY=
FMCSA_WEBKEY=

# --- App URLs ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- DEPRECATED (apps/worker only; the server owns the pipeline now) ---------
# The standalone BullMQ worker is deprecated and slated for removal in Phase 2.
# These are only read if you still run apps/worker locally.
# REDIS_URL=redis://localhost:6379
# WORKER_CONCURRENCY=4
# PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers
# WORKER_CALLBACK_SECRET=change-me
